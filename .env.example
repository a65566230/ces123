# LLM provider
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://ai.changyou.club/v1
OPENAI_WIRE_API=responses
OPENAI_REASONING_EFFORT=high
OPENAI_REASONING_SUMMARY=none
OPENAI_VERBOSITY=low
OPENAI_CONTEXT_WINDOW=1050000
OPENAI_AUTO_COMPACT_TOKEN_LIMIT=900000
OPENAI_DISABLE_RESPONSE_STORAGE=true

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Browser runtime
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
BROWSER_ARGS=
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_USER_AGENT=

# MCP runtime
MCP_SERVER_NAME=jshook-reverse-tool
MCP_SERVER_VERSION=2.0.1
JSHOOK_TOOL_PROFILE=expert
ENABLE_LEGACY_TOOLS=false

# Cache and analysis
ENABLE_CACHE=true
CACHE_DIR=.cache
CACHE_TTL=3600
MAX_CONCURRENT_ANALYSIS=3
MAX_CODE_SIZE_MB=10

# Logging and legacy helpers
LOG_LEVEL=info
CAPTCHA_SCREENSHOT_DIR=./screenshots
