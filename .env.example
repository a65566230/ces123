# LLM provider
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Browser runtime
BROWSER_ENGINE=puppeteer
PLAYWRIGHT_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000
BROWSER_ARGS=
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_USER_AGENT=

# MCP runtime
MCP_SERVER_NAME=jshook-reverse-tool
MCP_SERVER_VERSION=2.0.0
ENABLE_LEGACY_TOOLS=false

# Cache and analysis
ENABLE_CACHE=true
CACHE_DIR=.cache
CACHE_TTL=3600
MAX_CONCURRENT_ANALYSIS=3
MAX_CODE_SIZE_MB=10

# Logging and legacy helpers
LOG_LEVEL=info
CAPTCHA_SCREENSHOT_DIR=./screenshots
