{
  "name": "jshook-reverse-tool",
  "version": "2.0.1",
  "description": "Structured MCP toolkit for JavaScript reverse engineering with workflow-first tools, session tracking, and a Playwright-backed browser pool",
  "mcpName": "io.github.a65566230/jshook-reverse-tool",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "jshook-reverse-tool": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json",
    ".env.example",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/a65566230/ces123.git"
  },
  "bugs": {
    "url": "https://github.com/a65566230/ces123/issues"
  },
  "homepage": "https://github.com/a65566230/ces123#readme",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.config.cjs --runInBand --selectProjects unit",
    "test:integration": "jest --config jest.config.cjs --runInBand --selectProjects integration",
    "test:live:douyin:v2": "npm run build && tsx scripts/live-site-matrix.ts --surface v2 --runtime dist --tool-timeout-ms 20000",
    "test:live:douyin:legacy": "npm run build && tsx scripts/live-site-matrix.ts --surface legacy --runtime dist --tool-timeout-ms 60000",
    "test:live:douyin": "npm run build && tsx scripts/live-site-matrix.ts --surface v2 --runtime dist --tool-timeout-ms 20000 && tsx scripts/live-site-matrix.ts --surface legacy --runtime dist --tool-timeout-ms 60000",
    "test:watch": "jest --config jest.config.cjs --watch",
    "verify": "tsx scripts/verify-modules.ts",
    "report:tool-catalog": "tsx scripts/report-tool-catalog.ts",
    "benchmark:v2:fixtures": "tsx scripts/benchmark-v2-fixtures.ts",
    "benchmark:acceptance:fixtures": "tsx scripts/benchmark-acceptance-fixtures.ts",
    "evaluate:mcp2cli": "tsx scripts/evaluate-mcp2cli.ts",
    "benchmark:codex:real": "tsx scripts/run-codex-real-benchmark.ts",
    "summarize:real-benchmarks": "tsx scripts/summarize-real-benchmarks.ts",
    "verify:manifest": "tsx scripts/validate-server-manifest.ts",
    "verify:skill": "tsx scripts/validate-skill.ts",
    "package:smoke": "tsx scripts/package-smoke-test.ts",
    "verify:build": "npm run build && npm run verify && npm run verify:manifest && npm run verify:skill",
    "lint": "eslint src scripts tests --ext .ts --max-warnings=0",
    "format": "prettier --write \"{src,scripts,tests,skills}/**/*.{ts,js,mjs,cjs,md,json,yml,yaml}\" README.md package.json server.json .env.example",
    "prepare": "npm run build",
    "check": "npm run lint && npm run typecheck && npm run test && npm run verify && npm run verify:manifest && npm run verify:skill && npm run package:smoke",
    "package": "npm run build && npm pack",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "javascript",
    "reverse-engineering",
    "hook",
    "hooking",
    "deobfuscation",
    "ai",
    "claude",
    "debugger",
    "runtime-analysis",
    "source-maps",
    "browser-automation",
    "network-monitoring",
    "ast",
    "obfuscation",
    "cryptography-detection",
    "code-analysis",
    "workflow-tools",
    "agent-skill"
  ],
  "author": {
    "name": "a65566230",
    "url": "https://github.com/a65566230"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@babel/generator": "^7.26.5",
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.5",
    "@babel/types": "^7.26.3",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "lru-cache": "^10.4.3",
    "openai": "^4.73.0",
    "ora": "^8.1.1",
    "playwright-core": "^1.53.1"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
